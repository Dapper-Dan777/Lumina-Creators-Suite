# Copy to .env and fill values (DO NOT commit secrets)
# Database
DATABASE_URL=postgres://lumina:lumina@db:5432/lumina
# Redis (optional)
REDIS_URL=redis://redis:6379

# onlyfansapi external provider credentials
# Use your onlyfansapi token here, not a direct OnlyFans key.
ONLYFANS_BASE_URL=https://app.onlyfansapi.com/api
ONLYFANS_API_KEY=
ONLYFANS_API_KEY_HEADER=Authorization
ONLYFANS_API_KEY_PREFIX=Bearer 
ONLYFANS_PROFILE_SLUG=madison420ivy

# Legacy / optional direct auth fields (not needed for onlyfansapi)
ONLYFANS_CLIENT_ID=
ONLYFANS_CLIENT_SECRET=
ONLYFANS_ACCESS_TOKEN=

# App
SESSION_SECRET=change-me-random-string

# For ngrok (optional)
NGROK_AUTH_TOKEN=

# n8n (optional - self-hosted)
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=
