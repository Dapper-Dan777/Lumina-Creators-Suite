# Copy to .env and fill values (DO NOT commit secrets)

# SQLite — keine externe DB nötig (Docker + lokal)
DATABASE_URL=file:./server/data/lumina.db

# Öffentlicher Zugang ohne Vercel: npm run public
# DuckDNS (gratis Subdomain): https://www.duckdns.org
DUCKDNS_DOMAIN=lumina
DUCKDNS_TOKEN=

# Mobile App (Capacitor / TestFlight) — HTTPS-URL von npm run public
CAPACITOR_SERVER_URL=https://deine-tunnel-url.trycloudflare.com
# Redis (optional)
REDIS_URL=redis://redis:6379

# onlyfansapi.com — https://app.onlyfansapi.com/api-keys
# API-Key beginnt mit ofapi_ (niemals im Frontend speichern)
ONLYFANS_BASE_URL=https://app.onlyfansapi.com/api
ONLYFANS_API_KEY=
ONLYFANS_API_KEY_HEADER=Authorization
ONLYFANS_API_KEY_PREFIX=Bearer
# (mit oder ohne Leerzeichen — der Server normalisiert zu "Bearer <key>")
# Optional: OF-Username zum Filtern wenn mehrere Accounts verbunden sind
ONLYFANS_PROFILE_SLUG=
# Optional: direkte Account-ID aus OnlyFansAPI Console (acct_…)
ONLYFANS_ACCOUNT_ID=

# Legacy / optional direct auth fields (not needed for onlyfansapi)
ONLYFANS_CLIENT_ID=
ONLYFANS_CLIENT_SECRET=
ONLYFANS_ACCESS_TOKEN=

# AI — OpenAI-compatible API (Key nur serverseitig)
# OpenAI:  AI_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o-mini
# xAI:     AI_BASE_URL=https://api.x.ai/v1        AI_MODEL=grok-3-mini
AI_API_KEY=
# Open WebUI (Docker): http://host.docker.internal:3000/api/v1
# Ollama direkt:       http://host.docker.internal:11434/v1  + AI_API_KEY=ollama
AI_BASE_URL=http://host.docker.internal:3000/api/v1
AI_MODEL=codellama:7b-instruct-q4_K_M
AI_PROVIDER=openwebui

# Talent Scout — Google-Suche (empfohlen für Scout-Tab)
# Anleitung:
#   1. https://serper.dev öffnen → Sign up (Google/GitHub)
#   2. Dashboard → API Key kopieren
#   3. Hier einfügen: SERPER_API_KEY=dein_key
#   4. docker compose up -d --build api
# Kostenlos: ~2.500 Google-Suchen gratis, danach Pay-as-you-go (~$0.30/1000)
SERPER_API_KEY=
SERPER_GL=de
SERPER_HL=de

# App
SESSION_SECRET=change-me-random-string

# For ngrok (optional)
NGROK_AUTH_TOKEN=

# n8n (optional — separate Docker container, not bundled in the app)
# Server-seitig (API → n8n):
#   Lokal:              N8N_BASE_URL=http://localhost:5678
#   App in Docker:      N8N_BASE_URL=http://host.docker.internal:5678
# Server-seitig (API → n8n, iframe läuft über /embed/n8n/ auf dem App-Port):
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_PUBLISH_PORT=5678
